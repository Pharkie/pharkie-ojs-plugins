# Staging environment — use strong generated passwords.
# Copy to .env.staging (or .env on the staging server) before deploying.

# === WordPress (Bedrock) ===
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=                    # openssl rand -base64 24
DB_HOST=wp-db
WP_ENV=staging
WP_HOME=https://staging-wp.example.com
WP_SITEURL=${WP_HOME}/wp
WP_DEBUG_LOG=/var/www/html/web/app/uploads/debug.log
WP_ADMIN_PASSWORD=              # openssl rand -base64 24

# WP-OJS integration
WPOJS_API_KEY=                # openssl rand -hex 32
WPOJS_BASE_URL=http://ojs:80/index.php/ea

# WordPress database (Docker Compose)
WP_DB_ROOT_PASSWORD=            # openssl rand -base64 24
WP_DB_PASSWORD=                 # openssl rand -base64 24

# === OJS ===
OJS_DB_HOST=ojs-db
OJS_DB_USER=ojs
OJS_DB_PASSWORD=                # openssl rand -base64 24
OJS_DB_NAME=ojs
OJS_DB_ROOT_PASSWORD=           # openssl rand -base64 24
OJS_BASE_URL=https://staging-ojs.example.com
OJS_TIMEZONE=Europe/London
OJS_ADMIN_USER=admin
OJS_ADMIN_PASSWORD=              # openssl rand -base64 24
OJS_ADMIN_EMAIL=

# Journal metadata (used by setup-ojs.sh)
# Required vars are marked [required] — setup will fail if missing.
OJS_JOURNAL_PATH=                                                                          # [required] URL path segment
OJS_JOURNAL_NAME=                                                                          # [required] Full journal title
OJS_JOURNAL_ACRONYM=
OJS_JOURNAL_ABBREVIATION=
OJS_JOURNAL_CONTACT_NAME=                                                                  # [required] Primary contact
OJS_JOURNAL_CONTACT_EMAIL=                                                                 # [required] Contact email
OJS_JOURNAL_PUBLISHER=                                                                     # Publisher name
OJS_JOURNAL_PUBLISHER_URL=                                                                 # Publisher URL
OJS_JOURNAL_PRINT_ISSN=                                                                    # Print ISSN
OJS_JOURNAL_ONLINE_ISSN=                                                                   # Online ISSN
OJS_JOURNAL_COUNTRY=                                                                       # Country code
OJS_JOURNAL_DESCRIPTION=
OJS_JOURNAL_ABOUT=
OJS_JOURNAL_SUBSCRIPTION_INFO=
# Theme options (OJS default theme)
OJS_THEME_COLOUR=#b91515
OJS_THEME_TYPOGRAPHY=notoSans
OJS_THEME_SHOW_DESCRIPTION=1
# Subscription types: pipe-separated "Name:Cost" entries (currency set via payments config)
OJS_SUB_TYPES=
# Non-member purchase fees
OJS_PURCHASE_ARTICLE_FEE=3
OJS_PURCHASE_ISSUE_FEE=25
# PayPal sandbox credentials (https://developer.paypal.com/dashboard/applications/sandbox)
OJS_PAYPAL_ACCOUNT=
OJS_PAYPAL_CLIENT_ID=
OJS_PAYPAL_SECRET=
OJS_PAYPAL_TEST_MODE=1

# DOI / Crossref (optional — only needed if registering DOIs)
OJS_DOI_PREFIX=
OJS_DOI_DEPOSITOR_NAME=
OJS_DOI_DEPOSITOR_EMAIL=
OJS_CROSSREF_USERNAME=
OJS_CROSSREF_PASSWORD=

# ORCID integration (optional — display-only with Public API, push works with Member API)
# API type: publicProduction, publicSandbox, memberProduction, memberSandbox
OJS_ORCID_API_TYPE=
OJS_ORCID_CLIENT_ID=
OJS_ORCID_CLIENT_SECRET=
OJS_ORCID_CITY=

# WP-OJS plugin config (OJS side)
WPOJS_API_KEY_SECRET=          # openssl rand -hex 32
WPOJS_ALLOWED_IPS=172.0.0.0/8
WPOJS_WP_MEMBER_URL=https://staging-wp.example.org
WPOJS_SUPPORT_EMAIL=
# UI messages shown to members (supports placeholders: {supportEmail}, {wpUrl})
WPOJS_DEFAULT_LOGIN_HINT="Member? Log in with your membership email and password."
WPOJS_DEFAULT_PAYWALL_HINT="If you believe you should have access through your membership, please contact <a href=\"mailto:{supportEmail}\">{supportEmail}</a>."
WPOJS_DEFAULT_FOOTER_MESSAGE="Your journal access is provided by your membership. <a href=\"{wpUrl}\">Manage your membership</a>."
WPOJS_DEFAULT_PASSWORD_RESET_HINT='Members: <a href="{wpResetUrl}">change your password on the membership website</a> — it will sync to the journal automatically. Passwords set here may be overwritten by your membership password.'

# Email (configure for staging)
OJS_SMTP_ENABLED=On
OJS_SMTP_HOST=smtp.example.com
OJS_SMTP_PORT=587
OJS_SMTP_AUTH=tls
OJS_SMTP_USER=
OJS_SMTP_PASSWORD=
OJS_MAIL_FROM=noreply@example.com

# Caddy SSL (only needed with docker-compose.caddy.yml overlay)
CADDY_WP_DOMAIN=staging-wp.example.com
CADDY_WP_AUTH_USER=staging
CADDY_WP_AUTH_HASH=                 # caddy hash-password --plaintext 'your-password'
CADDY_OJS_DOMAIN=staging-ojs.example.com

# Auth salts (generate with: wp dotenv salts generate)
AUTH_KEY=                       # openssl rand -base64 48
SECURE_AUTH_KEY=                # openssl rand -base64 48
LOGGED_IN_KEY=                  # openssl rand -base64 48
NONCE_KEY=                      # openssl rand -base64 48
AUTH_SALT=                      # openssl rand -base64 48
SECURE_AUTH_SALT=               # openssl rand -base64 48
LOGGED_IN_SALT=                 # openssl rand -base64 48
NONCE_SALT=                     # openssl rand -base64 48
