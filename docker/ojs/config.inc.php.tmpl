; OJS configuration — generated from template by entrypoint.sh.
; Environment-specific values use ${VAR} substitution.
; Everything else is at OJS defaults.

;;;;;;;;;;;;;;;;;;
; General Settings
;;;;;;;;;;;;;;;;;;

[general]
app_key = ${OJS_APP_KEY}
installed = Off
base_url = "${OJS_BASE_URL}"
restful_urls = On
session_cookie_name = OJSSID
session_lifetime = 30
scheduled_tasks = On
time_zone = "${OJS_TIMEZONE}"
date_format_short = Y-m-d
date_format_long = F j, Y
datetime_format_short = Y-m-d h:i A
datetime_format_long = F j, Y - h:i A
time_format = h:i A
allowed_html = a[href|target|title],em,strong,cite,code,ul,ol,li[class],dl,dt,dd,b,i,u,img[src|alt],sup,sub,br,p

;;;;;;;;;;;;;;;;;;;;;;;
; Localization Settings
;;;;;;;;;;;;;;;;;;;;;;;

[i18n]
locale = en
connection_charset = utf8

;;;;;;;;;;;;;;;;;;;
; Database Settings
;;;;;;;;;;;;;;;;;;;

[database]
driver = mysqli
host = ${OJS_DB_HOST}
username = ${OJS_DB_USER}
password = ${OJS_DB_PASSWORD}
name = ${OJS_DB_NAME}

;;;;;;;;;;;;;;;;;;
; Cache Settings
;;;;;;;;;;;;;;;;;;

[cache]
cache = file
web_cache = Off
web_cache_hours = 1

;;;;;;;;;;;;;;;;;;;
; Security Settings
;;;;;;;;;;;;;;;;;;;

[security]
force_ssl = Off
force_login_ssl = Off
api_key_secret = ${OJS_API_KEY_SECRET}
password_reset_timeout = 7

;;;;;;;;;;;;;;
; File Settings
;;;;;;;;;;;;;;

[files]
files_dir = /var/www/files
public_files_dir = public

;;;;;;;;;;;;;;;;;;
; Email Settings
;;;;;;;;;;;;;;;;;;

[email]
default = sendmail
default_envelope_sender = ${OJS_MAIL_FROM}
smtp = ${OJS_SMTP_ENABLED}
smtp_server = ${OJS_SMTP_HOST}
smtp_port = ${OJS_SMTP_PORT}
smtp_auth = ${OJS_SMTP_AUTH}
smtp_username = ${OJS_SMTP_USER}
smtp_password = ${OJS_SMTP_PASSWORD}

;;;;;;;;;;;;;;;;;;;
; Search Settings
;;;;;;;;;;;;;;;;;;;

[search]
index = On
min_word_length = 3
results_per_keyword = 500
; PDF indexing disabled: split PDFs have page bleed from adjacent articles,
; causing false matches. HTML galleys are still indexed (built-in handler).
index[application/pdf] =

;;;;;;;;;;;;;;;;;;;
; OAI Settings
;;;;;;;;;;;;;;;;;;;

[oai]
oai = On
repository_id = ojs2.localhost

;;;;;;;;;;;;;;;;;;
; WP-OJS Integration
;;;;;;;;;;;;;;;;;;

;;;;;;;;;;;;;;
; Job Queue
;;;;;;;;;;;;;;

[queues]
default_connection = "database"
default_queue = "queue"

; Process jobs at the end of each web request.
; Fine for low-traffic sites. For high-traffic, use a worker daemon instead.
; See: https://docs.pkp.sfu.ca/admin-guide/en/deploy-jobs
job_runner = On

; Max jobs per request / max seconds per request
job_runner_max_jobs = 30
job_runner_max_execution_time = 30

;;;;;;;;;;;;;;;;;;;;;
; WP-OJS Integration
;;;;;;;;;;;;;;;;;;;;;

[wpojs]
; api_key_secret is in [security] section (OJS masks it on System Info page)
allowed_ips = ${WPOJS_ALLOWED_IPS}
wp_member_url = ${WPOJS_WP_MEMBER_URL}
support_email = ${WPOJS_SUPPORT_EMAIL}

; UI messages (login hint, paywall hint, footer) are stored in plugin_settings
; (DB), not here. PHP INI files corrupt values containing " and {} (HTML with
; href="..." and {placeholder}). setup-ojs.sh writes instance-specific defaults
; to the DB during setup. Admins can further edit via the plugin Settings page.

;;;;;;;;;;;;;;
; QA Splits
;;;;;;;;;;;;;;

[qa-splits]
backfill_output_dir = "/data/sample-issues"
