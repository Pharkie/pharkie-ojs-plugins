# Umami analytics (self-hosted) vhost. Owned by pharkie-ojs-plugins.
# Only active when the umami overlay is running; if CADDY_UMAMI_DOMAIN is unset
# it falls back to an inert localhost address so this snippet stays valid.
{$CADDY_UMAMI_DOMAIN:http://localhost:8083} {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	reverse_proxy umami:3000
}
