# Shared edge reverse proxy for the SEA box.
#
# This file is intentionally a stable one-liner — DO NOT add vhosts here.
# Each project owns its own snippet in the shared drop-in directory
# /etc/caddy/conf.d/<project>.caddy (bind-mounted from /opt/caddy-conf.d on the
# host). One file per project = no shared-file edits, no merge collisions, and
# `git pull` on this repo never aborts on a locally-edited Caddyfile.
#
# Caddy runs with --watch, so dropping/editing a snippet auto-reloads.
# pharkie-ojs-plugins' own snippets (wp/ojs/umami) are version-controlled in
# docker/caddy/conf.d/ and synced to /opt/caddy-conf.d on deploy.
#
# See docs/shared-caddy.md for the full convention.

import /etc/caddy/conf.d/*.caddy
