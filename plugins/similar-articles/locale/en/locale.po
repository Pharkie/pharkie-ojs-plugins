msgid "plugins.generic.similarArticles.displayName"
msgstr "Faster Related Articles"

msgid "plugins.generic.similarArticles.description"
msgstr "Faster, smarter drop-in replacement for the stock Recommend Articles by Similarity plugin. Similarity is pre-computed offline using a hybrid of TF-IDF and sentence embeddings; the article page reads from a cache table at render time (sub-millisecond). Handles corpus-wide keywords that collapse the stock plugin, and catches semantically-related papers that share no lexical tokens."
