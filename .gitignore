# macOS
.DS_Store

# Claude Code runtime data
.claude-home/

# Test lockfile
.playwright-lock

# Private docs + env files (cloned from Pharkie/ojs-sea-private)
docs/private/

# Environment
.env
.env.dev
.env.staging
.env.live
.env.production

# WordPress (Bedrock) — all Composer-managed
wordpress/web/wp/
wordpress/vendor/
wordpress/web/app/plugins/
wordpress/web/app/mu-plugins/
wordpress/web/app/themes/
wordpress/web/app/uploads/
wordpress/web/app/cache/
wordpress/web/wp-content
wordpress/paid-plugins/*/
!wordpress/paid-plugins/README.md
wordpress/themes/*/
!wordpress/themes/README.md

# DB snapshots
docker/snapshots/

# Database backups (pulled from VPS)
backups/

# Data exports (live WP exports, journal archive PDFs, plugin zips)
/data-export/
e2e/screenshots/

# Rebuild logs
logs/

# Backfill pipeline output — large binary files (split PDFs, XML)
backfill/output/*
!backfill/output/*/
backfill/output/*/*.pdf
backfill/output/*/*.xml
backfill/output/*/*.csv
backfill/output/audit-report.*
backfill/output/review-all.csv
backfill/output/*.png
# toc.json is tracked in git — it's the irreplaceable human-reviewed metadata
!backfill/output/*/toc.json
# HTML galleys are tracked — generated by htmlgen.py (Haiku API), expensive to regenerate
!backfill/output/*/*.html
!backfill/output/htmlgen-report.json

# Backfill source PDFs (large)
backfill/input/

# Python bytecode
__pycache__/

# E2E test artifacts
node_modules/
test-results/
playwright-report/
e2e/test-results/
e2e/playwright-report/

# Added by ggshield
.cache_ggshield
plugins/stripe-payment/vendor/
